  "keyFeatures": [
    "AI Gateway with unified LLM API proxy supporting 40+ model providers",
    "MCP (Model Context Protocol) Server hosting for AI Agents",
    "Kubernetes Ingress Controller with Gateway API support",
    "Wasm plugin system supporting Go, Rust, and JavaScript",
    "Token-based rate limiting and AI observability",
    "Built-in WAF and authentication plugins (key-auth, JWT, OIDC)",
    "Zero-reload hot configuration updates via Envoy xDS",
    "Streaming SSE support with minimal memory overhead",
    "Microservice gateway with Nacos/ZooKeeper/Consul service discovery"
  ],
  "publicApiSurface": [
    "POST /v1/chat/completions (OpenAI-compatible LLM API)",
    "POST /v1/messages (Claude-compatible LLM API)",
    "POST /v1/embeddings (Embeddings API)",
    "POST /v1/images/generations (Image generation API)",
    "Wasm Plugin SDK (Go: github.com/higress-group/proxy-wasm-go-sdk)",
    "hgctl CLI (install, upgrade, config, plugin, dashboard)",
    "Helm chart: higress.io/higress",
    "WasmPlugin CRD",
    "McpBridge CRD",
    "Http2Rpc CRD",
    "Ingress API / Gateway API"
  ]
}
